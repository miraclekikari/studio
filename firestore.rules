rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils : Consultables par tous, modifiables uniquement par le propriétaire
    match /profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents : Consultables par tous, ajout par les connectés, modif/suppr par le propriétaire
    match /documents/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
  }
}